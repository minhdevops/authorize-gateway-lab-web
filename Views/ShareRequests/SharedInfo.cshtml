@model CitizenData
@{
    ViewData["Title"] = "Thông tin chia sẻ";
}

<div class="mb-3">
    <a class="btn btn-outline-secondary btn-sm" asp-action="Index">← Quay lại danh sách</a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white">
        <h4 class="fw-bold mb-1">Thông tin 8 trường chia sẻ</h4>
        <div class="text-muted">TransactionId: <strong>@ViewBag.TransactionId</strong></div>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-6"><div class="info-box"><span>CitizenId</span><strong>@Model.CitizenId</strong></div></div>
            <div class="col-md-6"><div class="info-box"><span>FullName</span><strong>@Model.FullName</strong></div></div>
            <div class="col-md-6"><div class="info-box"><span>DateOfBirth</span><strong>@Model.DateOfBirth.ToString("dd/MM/yyyy")</strong></div></div>
            <div class="col-md-6"><div class="info-box"><span>Gender</span><strong>@Model.Gender</strong></div></div>
            <div class="col-md-6"><div class="info-box"><span>Address</span><strong>@Model.Address</strong></div></div>
            <div class="col-md-6"><div class="info-box"><span>IssueDate</span><strong>@Model.IssueDate.ToString("dd/MM/yyyy")</strong></div></div>
            <div class="col-md-6"><div class="info-box"><span>IssuePlace</span><strong>@Model.IssuePlace</strong></div></div>
            <div class="col-md-6"><div class="info-box"><span>Nationality</span><strong>@Model.Nationality</strong></div></div>
        </div>
    </div>
</div>
